# Base URL of the Mendez Barbershop backend.
#
# You can use the exact same URL you use in the web client — the app will
# append `/api` automatically if you don't include it (the backend runs
# behind `app.setGlobalPrefix('api')`, which the web proxy already handles
# transparently).
#
# Common values while developing:
#   - Android emulator .............. http://10.0.2.2:3001
#   - iOS simulator ................. http://127.0.0.1:3001
#   - Physical device on same LAN ... http://192.168.x.x:3001
#   - VS Code / Cursor dev tunnel ... https://<name>-3001.use.devtunnels.ms
#   - Staging / production .......... https://api.mendez.example.com
API_BASE_URL=http://10.0.2.2:3001

# The barbershop (tenant) code is NOT set here — the seller enters it on the
# first launch of the app. It's then persisted in SharedPreferences and sent
# on every request as the `X-Tenant-Code` header.
