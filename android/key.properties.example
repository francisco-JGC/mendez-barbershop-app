# Copy this file to `android/key.properties` and fill in real values.
# `key.properties` and the .jks file are gitignored — never commit either.
#
# Generate the keystore once with:
#   keytool -genkey -v -keystore ~/mendez-release-key.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias mendez
#
# Then edit the values below and paste the absolute path to your .jks.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=mendez
storeFile=/absolute/path/to/mendez-release-key.jks
